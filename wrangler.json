{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-01-27",
  "main": "src/index.ts",
  "name": "openauthster-issuer",
  "upload_source_maps": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "QR_AUTH_DO",
        "class_name": "QRHandshake"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["QRHandshake"]
    }
  ],
  "d1_databases": [
    {
      "binding": "AUTH_DB",
      "database_id": "ed2717d1-ed2f-4c4b-9e3b-219fde9b320a",
      "remote": true,
      "migrations_dir": "drizzle/migrations"
    }
  ],
  "observability": {
    "enabled": true
  },
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "WEBUI_ADMIN_EMAILS": "justin@webcreas.com",
    "WEBUI_ORIGIN_URL": "http://localhost:3001",
    "ISSUER_URL": "https://openauthster-test.shpaw400.workers.dev",
    "LOG_ENABLED": "true",
    "ACCESS_TTL": "900",
    "REFRESH_TTL": "604800"
  }
}
